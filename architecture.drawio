        <mxCell id="preprocess-output" value="✅ APPROVED FOUNDATION (consumed by ALL 3 workflows)&#xa;requirement_analysis.json · solution.json · diagrams/*.drawio · chat_history.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
