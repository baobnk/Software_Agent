        <mxCell id="brd-sa4" value="P4 exporter&#xa;render .docx via subprocess (docxtpl)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="100" y="1050" width="620" height="35" as="geometry"/></mxCell>
        <mxCell id="brd-state" value="BRDState · brd_doc · issues · revision_count" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#d79b00;fontSize=10;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="100" y="1095" width="620" height="25" as="geometry"/></mxCell>

        <!-- WBS Workflow swimlane (simplified to 9 phases since discovery+architecture done upstream) -->
        <mxCell id="wbs-wf" value="WBS WORKFLOW · 9 phases (P1=module decomp · P2=task breakdown · P3=effort · P4=phase plan · P5=timeline · P6=cost · P7=validation · P8=template fill · P9=finalize)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;align=center;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
