        <mxCell id="prop-sa2" value="solution_pitcher" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1700" y="995" width="190" height="40" as="geometry"/></mxCell>
        <mxCell id="prop-sa3" value="case_study (RAG)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1900" y="995" width="220" height="40" as="geometry"/></mxCell>
        <mxCell id="prop-sa4" value="pricing_agent (reads cost.json)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1500" y="1045" width="300" height="35" as="geometry"/></mxCell>
        <mxCell id="prop-sa5" value="slide_layouter + exporter (python-pptx · subprocess)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1810" y="1045" width="310" height="35" as="geometry"/></mxCell>
        <mxCell id="prop-state" value="ProposalState · slides · diagrams (reused) · pricing_tiers · template_path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#d79b00;fontSize=10;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="1500" y="1090" width="620" height="30" as="geometry"/></mxCell>

        <!-- ⑥ TOOLS LAYER -->
        <mxCell id="L6-bg" value="⑥ ATOMIC TOOLS LAYER (~170 tools total) — Pydantic-validated, idempotent, section_id-keyed for incremental patches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;opacity=40;" vertex="1" parent="1">
