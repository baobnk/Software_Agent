        <mxCell id="wbs-p7" value="P7 validator · 10 tools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="990" y="1045" width="200" height="35" as="geometry"/></mxCell>
        <mxCell id="wbs-p8" value="P8 template_filler · 12 tools (openpyxl)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1200" y="1045" width="240" height="35" as="geometry"/></mxCell>
        <mxCell id="wbs-state" value="WBSState · wbs_doc · timeline · cost · domain_profile (75 tools total)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#d79b00;fontSize=10;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="780" y="1090" width="660" height="30" as="geometry"/></mxCell>

        <!-- Proposal Workflow swimlane -->
        <mxCell id="prop-wf" value="PROPOSAL WORKFLOW · reads requirement + solution + diagrams + cost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=center;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
