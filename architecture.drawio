        <!-- ② API GATEWAY -->
        <mxCell id="L2-bg" value="② API GATEWAY (FastAPI + SSE for chat-based feedback loop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="2120" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="api-sessions" value="POST /sessions&#xa;Create session + workspace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="255" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="api-files" value="POST /sessions/{id}/files&#xa;Upload requirement files" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="320" y="255" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="api-analyze" value="POST /sessions/{id}/analyze&#xa;Trigger Requirement Agent&#xa;(then Solution Agent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="560" y="255" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="api-chat" value="POST /sessions/{id}/chat (SSE)&#xa;★ Chat with Solution Agent&#xa;(feedback loop, refine solution)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="800" y="255" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="api-diagram" value="GET /sessions/{id}/diagram&#xa;Stream drawio XML preview&#xa;(updated after each refine)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1040" y="255" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="api-workflow" value="POST /sessions/{id}/run&#xa;{workflow: brd|wbs|proposal}&#xa;Reads approved solution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1280" y="255" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="api-approve" value="POST /sessions/{id}/approve&#xa;Resume after HITL gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1520" y="255" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="api-outputs" value="GET /sessions/{id}/outputs&#xa;List artifacts + presigned URLs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1760" y="255" width="220" height="70" as="geometry"/></mxCell>

        <!-- ③ ORCHESTRATION CORE -->
        <mxCell id="L3-bg" value="③ ORCHESTRATION CORE (per session, multi-tenant, lazy LLM client)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="2120" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="session-mgr" value="Session Manager&#xa;UUID · tenant_id · workspace dir" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="395" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="workflow-reg" value="Workflow Registry&#xa;@register(&quot;requirement&quot;)&#xa;@register(&quot;solution&quot;)&#xa;@register(&quot;brd&quot;) @(&quot;wbs&quot;) @(&quot;proposal&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="340" y="395" width="280" height="80" as="geometry"/></mxCell>
        <mxCell id="llm-factory" value="LLM Factory (lazy, per-session)&#xa;provider · api_key from session.request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="640" y="395" width="280" height="80" as="geometry"/></mxCell>
        <mxCell id="hitl-mgr" value="HITL + Chat Manager&#xa;interrupt_on for render_*&#xa;Conversational refinement loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="940" y="395" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="ws-mgr" value="Workspace Manager&#xa;CompositeFilesystemBackend&#xa;TTL cleanup 24h" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1200" y="395" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="checkpoint" value="Checkpointer&#xa;AsyncPostgresSaver&#xa;Restart-safe + HITL resume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1460" y="395" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="rate-limit" value="Rate Limiter + Queue&#xa;Per-tenant token bucket&#xa;Backpressure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1720" y="395" width="240" height="80" as="geometry"/></mxCell>

        <!-- ④ NEW: PRE-PROCESSING (Requirement + Solution agents) -->
        <mxCell id="L4-bg" value="④ PRE-PROCESSING — runs BEFORE downstream workflows. Output is consumed by all 3 workflows (BRD/WBS/Proposal)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8d5fc;strokeColor=#7B68A6;fontSize=14;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="2120" height="290" as="geometry"/>
        </mxCell>

        <!-- Requirement Agent (NEW) -->
        <mxCell id="req-agent" value="REQUIREMENT AGENT&#xa;(claude-sonnet-4-6)&#xa;━━━━━━━━━━━━━&#xa;EXTRACTS from input files:&#xa;• Business context + goals&#xa;• Stakeholders + roles&#xa;• Functional requirements (raw FRs)&#xa;• Non-functional requirements&#xa;• Constraints (budget, timeline,&#xa;  compliance, tech stack)&#xa;• Existing systems + integrations&#xa;• Domain (banking, insurance, ...)&#xa;• Scale + data volume&#xa;━━━━━━━━━━━━━&#xa;HITL: asks clarifying Qs if missing&#xa;critical info (max 5 questions)&#xa;━━━━━━━━━━━━━&#xa;Output: requirement_analysis.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8d5fc;strokeColor=#7B68A6;fontSize=10;fontStyle=1;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="540" width="380" height="240" as="geometry"/>
        </mxCell>

        <!-- Solution Proposal Agent (NEW) - the bigger one with chat loop -->
        <mxCell id="sol-agent" value="SOLUTION PROPOSAL AGENT (claude-sonnet-4-6)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;PROPOSES technical solution:&#xa;• Architecture pattern (mono / micro / serverless / hybrid) + rationale + alternatives&#xa;• Tech stack per layer (BE / FE / DB / cache / queue / search / AI / infra)&#xa;• Deployment topology (cloud / on-prem / hybrid · sizing · HA · DR)&#xa;• Integration patterns (gateway / ESB / event-driven / direct)&#xa;• Data architecture (schema strategy · retention · backup)&#xa;• Module decomposition (high-level)&#xa;• Security architecture (auth · encryption · secrets · audit · domain rules)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;DRAWS DIAGRAMS via MCP drawio:&#xa;• mcp__drawio__create_new_diagram   (system context)&#xa;• mcp__drawio__edit_diagram         (component + sequence)&#xa;• mcp__drawio__export_diagram       (PNG/SVG preview)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Output: solution.json + diagrams/{system_context,component,sequence,deployment}.drawio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8d5fc;strokeColor=#7B68A6;fontSize=10;fontStyle=1;align=left;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="540" width="900" height="240" as="geometry"/>
        </mxCell>

        <!-- Chat Feedback Loop visualization -->
        <mxCell id="chat-loop" value="💬 CHAT FEEDBACK LOOP (the differentiator)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;User → Web UI chat → SSE stream:&#xa;  &quot;Thay PostgreSQL bằng MongoDB&quot;&#xa;  &quot;Thêm Redis cache cho session&quot;&#xa;  &quot;Đổi sang microservices&quot;&#xa;  &quot;Bỏ message queue, dùng REST&quot;&#xa;  &quot;Tăng team thêm 1 BE&quot;&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Solution Agent reacts:&#xa;✓ Edits solution.json (atomic patch)&#xa;✓ Updates drawio via mcp__drawio__edit_diagram&#xa;✓ Re-validates against constraints&#xa;✓ Streams diff + new diagram preview&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;User: &quot;OK approve&quot; → unlock downstream workflows&#xa;Iteration count + diff history saved" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;align=left;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1440" y="540" width="700" height="240" as="geometry"/>
        </mxCell>

