        <mxCell id="brd-sa2" value="P2 critic_agent&#xa;Validate (FR_DUPLICATE,&#xa;NFR_NO_TARGET, ...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="410" y="975" width="155" height="65" as="geometry"/></mxCell>
