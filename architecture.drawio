        <mxCell id="langfuse" value="Langfuse / OpenTelemetry&#xa;Trace + cost tracking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1400" y="135" width="280" height="55" as="geometry"/></mxCell>
