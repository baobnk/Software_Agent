        <mxCell id="wbs-p1" value="P1 module decomp&#xa;5 tools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="780" y="995" width="155" height="40" as="geometry"/></mxCell>
